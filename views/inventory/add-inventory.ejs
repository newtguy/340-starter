<div class="add-inventory-page">
    <% if (title) { %>
    <h1><%= title %></h1>
    <% } %>

    <% messages() %>

    <!-- Validation Errors -->
    <% if (errors) { %>
    <% errors.array().forEach(err => { %>
        <p class="error"><%= err.msg %></p>
    <% }) %>
    <% } %>

    <form action="/inv/add-inventory" method="POST">

    <label for="inv_make">Make:</label>
    <input type="text" name="inv_make" id="inv_make" value="<%= inv_make || '' %>" required minlength="2">

    <label for="inv_model">Model:</label>
    <input type="text" name="inv_model" id="inv_model" value="<%= inv_model || '' %>" required minlength="2">

    <label for="inv_year">Year:</label>
    <input type="number" name="inv_year" id="inv_year" value="<%= inv_year || '' %>" min="1900" max="<%= new Date().getFullYear() + 1 %>" required>

    <label for="inv_description">Description:</label>
    <textarea name="inv_description" id="inv_description" required minlength="10"><%= inv_description || '' %></textarea>

    <label for="inv_image">Image Path:</label>
    <input type="text" name="inv_image" id="inv_image" value="<%= inv_image || '/images/no-image.png' %>" required>

    <label for="inv_thumbnail">Thumbnail Path:</label>
    <input type="text" name="inv_thumbnail" id="inv_thumbnail" value="<%= inv_thumbnail || '/images/no-image.png' %>" required>

    <label for="inv_price">Price ($):</label>
    <input type="number" step="0.01" name="inv_price" id="inv_price" value="<%= inv_price || '' %>" min="0" required>

    <label for="inv_miles">Mileage:</label>
    <input type="number" name="inv_miles" id="inv_miles" value="<%= inv_miles || '' %>" min="0" required>

    <label for="inv_color">Color:</label>
    <input type="text" name="inv_color" id="inv_color" value="<%= inv_color || '' %>" required>

    <label for="classificationList">Classification:</label>
    <%- classificationList %>

    <button type="submit">Add Vehicle</button>
    </form>
</div>